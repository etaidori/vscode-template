{
  "name": "project-template-generator",
  "displayName": "Project Template Generator",
  "description": "VS Code extension to generate new projects from templates with a type selector. All builds output to the 'package' folder.",
  "version": "0.0.6",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": ">=1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:projectTemplateGenerator.createProject"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projectTemplateGenerator.createProject",
        "title": "Create Project from Template"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package -o ./package/project-template-generator.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "@types/node": "^18.0.0",
    "typescript": "^4.7.4",
    "vsce": "^2.15.0"
  },
  "dependencies": {}
}
